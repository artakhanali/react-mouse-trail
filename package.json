{
  "name": "react-mouse-trail",
  "version": "1.0.0",
  "description": "Lightweight React component that spawns elements along your cursor path",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "mouse-trail.config.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "keywords": [
    "react",
    "mouse",
    "trail",
    "cursor",
    "animation",
    "effect",
    "interactive"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/artakhanali/react-mouse-trail"
  }
}
